{
  "runtime": "remote",
  "public_host": "gpu-box",
  "remote_map": "openvla=http://gpu-box:8001,pi0=http://gpu-box:8002,smolvla=http://gpu-box:8003,groot=http://gpu-box:8004",
  "compare_command": "vla-zoo compare pybullet --models openvla,pi0,smolvla,groot --runtime remote --remote-map openvla=http://gpu-box:8001,pi0=http://gpu-box:8002,smolvla=http://gpu-box:8003,groot=http://gpu-box:8004",
  "servers": [
    {
      "model": "openvla",
      "port": 8001,
      "host": "0.0.0.0",
      "public_url": "http://gpu-box:8001",
      "install_hint": "pip install -e \".[cli,server,openvla]\"",
      "command": [
        "vla-zoo",
        "serve",
        "--model",
        "openvla",
        "--host",
        "0.0.0.0",
        "--port",
        "8001",
        "--pretrained",
        "openvla/openvla-7b",
        "--device",
        "cuda:0",
        "--dtype",
        "bfloat16",
        "--unnorm-key",
        "bridge_orig"
      ],
      "notes": "Requires external OpenVLA weights and enough GPU memory.",
      "shell_command": "vla-zoo serve --model openvla --host 0.0.0.0 --port 8001 --pretrained openvla/openvla-7b --device cuda:0 --dtype bfloat16 --unnorm-key bridge_orig"
    },
    {
      "model": "pi0",
      "port": 8002,
      "host": "0.0.0.0",
      "public_url": "http://gpu-box:8002",
      "install_hint": "pip install -e \".[cli,server,openpi]\"",
      "command": [
        "vla-zoo",
        "serve",
        "--model",
        "pi0",
        "--host",
        "0.0.0.0",
        "--port",
        "8002",
        "--pretrained",
        "lerobot/pi0_base",
        "--device",
        "cuda:0"
      ],
      "notes": "Uses explicit LeRobot checkpoint selection; checkpoint compatibility is version-sensitive.",
      "shell_command": "vla-zoo serve --model pi0 --host 0.0.0.0 --port 8002 --pretrained lerobot/pi0_base --device cuda:0"
    },
    {
      "model": "smolvla",
      "port": 8003,
      "host": "0.0.0.0",
      "public_url": "http://gpu-box:8003",
      "install_hint": "pip install -e \".[cli,server,smolvla]\"",
      "command": [
        "vla-zoo",
        "serve",
        "--model",
        "smolvla",
        "--host",
        "0.0.0.0",
        "--port",
        "8003",
        "--pretrained",
        "lerobot/smolvla_base",
        "--device",
        "cuda:0",
        "--dtype",
        "bfloat16"
      ],
      "notes": "Uses LeRobot policy loading with multi-camera/state observations.",
      "shell_command": "vla-zoo serve --model smolvla --host 0.0.0.0 --port 8003 --pretrained lerobot/smolvla_base --device cuda:0 --dtype bfloat16"
    },
    {
      "model": "groot",
      "port": 8004,
      "host": "0.0.0.0",
      "public_url": "http://gpu-box:8004",
      "install_hint": "Install the external GR00T stack, then pip install -e \".[cli,server,groot]\"",
      "command": [
        "vla-zoo",
        "serve",
        "--model",
        "groot",
        "--host",
        "0.0.0.0",
        "--port",
        "8004"
      ],
      "notes": "Experimental placeholder until an external GR00T runtime is wired in.",
      "shell_command": "vla-zoo serve --model groot --host 0.0.0.0 --port 8004"
    }
  ]
}
