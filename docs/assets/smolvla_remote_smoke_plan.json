{
  "model_name": "smolvla",
  "pretrained": "lerobot/smolvla_base",
  "host": "0.0.0.0",
  "public_host": "gpu-box",
  "port": 8000,
  "public_url": "http://gpu-box:8000",
  "device": "cuda:0",
  "dtype": null,
  "venv_dir": ".venv-smolvla",
  "extras": "cli,server,smolvla",
  "instruction": "pick up the red block",
  "env_create_command": [
    "python3",
    "-m",
    "venv",
    ".venv-smolvla"
  ],
  "install_command": [
    ".venv-smolvla/bin/pip",
    "install",
    "-e",
    ".[cli,server,smolvla]"
  ],
  "server_command": [
    "vla-zoo",
    "serve",
    "--model",
    "smolvla",
    "--host",
    "0.0.0.0",
    "--port",
    "8000",
    "--pretrained",
    "lerobot/smolvla_base",
    "--device",
    "cuda:0"
  ],
  "health_command": [
    "curl",
    "-fsS",
    "http://gpu-box:8000/health"
  ],
  "predict_probe_command": [
    ".venv-smolvla/bin/python",
    "examples/python/smolvla_remote_client.py",
    "--remote-url",
    "http://gpu-box:8000",
    "--instruction",
    "pick up the red block"
  ],
  "compare_command": [
    "vla-zoo",
    "compare",
    "pybullet",
    "--models",
    "smolvla",
    "--runtime",
    "remote",
    "--remote-map",
    "smolvla=http://gpu-box:8000"
  ],
  "ros_plan_command": [
    "vla-zoo",
    "ros",
    "remote-smoke-report",
    "--model",
    "smolvla",
    "--remote-url",
    "http://gpu-box:8000",
    "--output-dir",
    "results/ros2_remote_smoke",
    "--duration-sec",
    "30"
  ],
  "caveat": "SmolVLA needs the pinned lerobot[smolvla] stack, which conflicts with the openvla extra; keep it in a dedicated virtual environment. This plan records no /v1/predict response and makes no policy-quality or task-success claim.",
  "env_create_command_shell": "python3 -m venv .venv-smolvla",
  "install_command_shell": ".venv-smolvla/bin/pip install -e '.[cli,server,smolvla]'",
  "server_command_shell": "vla-zoo serve --model smolvla --host 0.0.0.0 --port 8000 --pretrained lerobot/smolvla_base --device cuda:0",
  "health_command_shell": "curl -fsS http://gpu-box:8000/health",
  "predict_probe_command_shell": ".venv-smolvla/bin/python examples/python/smolvla_remote_client.py --remote-url http://gpu-box:8000 --instruction 'pick up the red block'",
  "compare_command_shell": "vla-zoo compare pybullet --models smolvla --runtime remote --remote-map smolvla=http://gpu-box:8000",
  "ros_plan_command_shell": "vla-zoo ros remote-smoke-report --model smolvla --remote-url http://gpu-box:8000 --output-dir results/ros2_remote_smoke --duration-sec 30"
}
