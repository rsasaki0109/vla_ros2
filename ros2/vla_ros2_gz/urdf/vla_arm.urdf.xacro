<?xml version="1.0"?>
<robot name="vla_arm" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- Minimal 7-DoF arm for Gazebo smoke tests. Joint names match vla_smoke_input_node. -->

  <link name="world"/>
  <link name="base_link">
    <visual>
      <geometry><cylinder length="0.05" radius="0.12"/></geometry>
      <origin xyz="0 0 0.025"/>
      <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder length="0.05" radius="0.12"/></geometry>
      <origin xyz="0 0 0.025"/>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0.025"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
  </link>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.05"/>
  </joint>

  <xacro:macro name="arm_link" params="name length color">
    <link name="${name}">
      <visual>
        <geometry><box size="0.06 0.06 ${length}"/></geometry>
        <origin xyz="0 0 ${length/2}"/>
        <material name="${name}_mat"><color rgba="${color}"/></material>
      </visual>
      <collision>
        <geometry><box size="0.06 0.06 ${length}"/></geometry>
        <origin xyz="0 0 ${length/2}"/>
      </collision>
      <inertial>
        <mass value="0.5"/>
        <origin xyz="0 0 ${length/2}"/>
        <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
      </inertial>
    </link>
  </xacro:macro>

  <xacro:arm_link name="link_1" length="0.18" color="0.8 0.2 0.1 1"/>
  <xacro:arm_link name="link_2" length="0.16" color="0.1 0.1 0.1 1"/>
  <xacro:arm_link name="link_3" length="0.14" color="0.8 0.2 0.1 1"/>
  <xacro:arm_link name="link_4" length="0.12" color="0.1 0.1 0.1 1"/>
  <xacro:arm_link name="link_5" length="0.10" color="0.8 0.2 0.1 1"/>
  <xacro:arm_link name="link_6" length="0.08" color="0.1 0.1 0.1 1"/>

  <link name="gripper_link">
    <visual>
      <geometry><box size="0.04 0.08 0.02"/></geometry>
      <material name="gripper_mat"><color rgba="0.2 0.6 0.9 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.04 0.08 0.02"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <xacro:macro name="revolute_joint" params="name parent child xyz">
    <joint name="${name}" type="revolute">
      <parent link="${parent}"/>
      <child link="${child}"/>
      <origin xyz="${xyz}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-2.5" upper="2.5" effort="80" velocity="2.0"/>
      <dynamics damping="0.4" friction="0.1"/>
    </joint>
  </xacro:macro>

  <xacro:revolute_joint name="joint_1" parent="base_link" child="link_1" xyz="0 0 0.05"/>
  <xacro:revolute_joint name="joint_2" parent="link_1" child="link_2" xyz="0 0 0.18"/>
  <xacro:revolute_joint name="joint_3" parent="link_2" child="link_3" xyz="0 0 0.16"/>
  <xacro:revolute_joint name="joint_4" parent="link_3" child="link_4" xyz="0 0 0.14"/>
  <xacro:revolute_joint name="joint_5" parent="link_4" child="link_5" xyz="0 0 0.12"/>
  <xacro:revolute_joint name="joint_6" parent="link_5" child="link_6" xyz="0 0 0.10"/>

  <joint name="gripper" type="prismatic">
    <parent link="link_6"/>
    <child link="gripper_link"/>
    <origin xyz="0 0 0.08"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="0.04" effort="20" velocity="0.2"/>
    <dynamics damping="0.2" friction="0.05"/>
  </joint>

  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <xacro:macro name="position_joint" params="name initial">
      <joint name="${name}">
        <command_interface name="position">
          <param name="min">-2.5</param>
          <param name="max">2.5</param>
        </command_interface>
        <state_interface name="position">
          <param name="initial_value">${initial}</param>
        </state_interface>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
    </xacro:macro>
    <xacro:position_joint name="joint_1" initial="0.0"/>
    <xacro:position_joint name="joint_2" initial="-0.35"/>
    <xacro:position_joint name="joint_3" initial="0.55"/>
    <xacro:position_joint name="joint_4" initial="-0.2"/>
    <xacro:position_joint name="joint_5" initial="0.0"/>
    <xacro:position_joint name="joint_6" initial="0.25"/>
    <joint name="gripper">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">0.04</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.04</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find vla_ros2_gz)/config/vla_arm_controllers.yaml</parameters>
    </plugin>
  </gazebo>
</robot>
